#!/bin/bash
### Lazyness enablers

# Change to the Code directory
alias code=cd ~/Code

# Create a new tmux session
alias new='tmux new -s'

# Attach to a tmux session
alias att="tmux attach -t"

# Find a file from where we are
alias ff='find . -iname'

# Useful for debugging dependency issues
alias freeze-mvn="mvn -o dependency:list |\
  grep \":.*:.*:.*\" |\
  cut -d] -f2- |\
  sed 's/:[a-z]*$//g' |\
  sort -u
"
# Sometimes it's nice for somebody to answer you
alias wtf="echo 'INDEED!'"

# Stick a uuid on my clipboard
alias uuid-me="uuid | pbcopy"
