export DOTFILES="$HOME/dotfiles"
export SCRIPTS="$HOME/scripts"
# Source the gmg_vars script to get service env vars
. ~/Code/fabric/gmg_vars.sh

# Load Laithisms
. "$DOTFILES/.aliases"

# Nasty fat hobitsis keeps his secret keys here
. "$DOTFILES/.secrets"

# Colorize maven
. "$SCRIPTS/colourise_mvn"

# Work files are sourced from .work, at preset it sets
# A $JOB_NAMESPACE env var is used to find the directory
# containing files which need to be sourced
export JOB_NAMESPACE='gmg'
# Okay, so now souce the work script to load in work specific scripts
. "$DOTFILES/.work"

export JAVA_HOME="/Library/Internet Plug-Ins/JavaAppletPlugin.plugin/Contents/Home"
export PATH=$PATH:$SCRIPTS

# AWS keys for scaldoge
export_aws

# We're probably going to want to start off in Code
cd ~/Code
