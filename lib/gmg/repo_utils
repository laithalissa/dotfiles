alias gerrit-projects='ssh -p 29418 stash gerrit ls-projects'

# A default selection of projects we want to manage: these are ones which
# will be needed by most devs
# You can override this list in your .zshrc_personal; make sure you also
# categorise them into the vars below if you want compile to work, for example
ALL_PROJECTS=(
  shop pay gideon playfireweb quarry
  laughingarcher greenleaf glowingninja cloudnine reservoir keystone
  couchviews nodestock puppet setup
)
# Add projects here if they should have the flake8 hook when cloning
PYTHON_PROJECTS=(shop pay gideon playfireweb quarry)
# Add projects here if they should be compiled with sbt (NOT sbt-0.7.7)
SBT_PROJECTS=(laughingarcher greenleaf glowingninja cloudnine keystone reservoir)
# Add projects here if they should be compiled with maven
MAVEN_PROJECTS=(inglewood)

CODE_ROOT="$HOME/Code"

export ALL_PROJECTS PYTHON_PROJECTS SBT_PROJECTS MAVEN_PROJECTS


LOG_DIR='/tmp/repo_util_logs'
CHANGE_ID_HOOK='/opt/gmg/hooks/gerrit-commit-msg'
FLAKE8_HOOK='/opt/gmg/hooks/flake8-pre-commit'

# Colours
RED='\e[1;31m'
GREEN='\e[1;32m'
YELLOW='\e[1;33m'
RESET='\e[0m'

# Convenient strings
FAILED="[ ${RED}FAILED$RESET ]"
OK="[ ${GREEN}OK$RESET ]"
SKIPPED="[ ${YELLOW}SKIPPED$RESET ]"

STATUS=0
REPO_DIR=''

# An ugly but sadly necessary hack to allow shop and pay
# To be in different directories to their repo names
_hack_repo_name() {
  prefix_repos=(shop pay)
  if [[ $prefix_repos =~ $1 ]]; then
    REPO_DIR="gmg$1"
  else
    REPO_DIR=$1
  fi
}

# Rebase the specified project if it's on the master branch
# If it's not on master, you should do it manually.
_rebase() {
  working_dir=`pwd`
  _hack_repo_name $1

  if [ ! -d $CODE_ROOT/$REPO_DIR ]; then
    echo "$1 is not a valid project on your system. Have you cloned it? $FAILED"
    return
  fi

  if [[ $2 == '' ]]; then
    branch='master'
  else
    branch="$2"
  fi

  logfile="$LOG_DIR/$1-rebase-`date '+%Y-%m-%d_%H:%M:%S'`.log"

  if [ ! -d $LOG_DIR ]; then
    mkdir $LOG_DIR
  fi

  cd $CODE_ROOT/$REPO_DIR

  if [[ `git branch | grep "^*"` != '* master' ]]; then
    echo "Project $1: not on master branch $SKIPPED"
    cd $working_dir
    unset working_dir
    return
  fi

  printf "Project $1: fetch upstream/$branch... "
  git fetch upstream &>> $logfile
  printf "rebase... "
  git rebase upstream/$branch &>> $logfile

  if [[ $? != 0 ]]; then
    git rebase --abort &>> $logfile
    echo "$FAILED"
    STATUS=`expr $STATUS + 1`
  else
    echo "$OK"
  fi

  cd $working_dir
  unset working_dir
}

# Compile the specified scala project. If the second argument is 'maven', use maven
# Otherwise use sbt to compile it
_compile() {
  working_dir=`pwd`
  _hack_repo_name $1

  if [ ! -d $CODE_ROOT/$1 ]; then
    echo "$1 is not a valid project $FAILED"
    STATUS=`expr $STATUS + 1`
    return
  fi
  if [ ! -d $CODE_ROOT/$1/src/main/scala ]; then
    echo "$1 is not a scala project $FAILED"
    STATUS=`expr $STATUS + 1`
    return
  fi

  logfile="$LOG_DIR/$1-compile-`date '+%Y-%m-%d_%H:%M:%S'`.log"

  if [ ! -d $LOG_DIR ]; then
    mkdir $LOG_DIR
  fi

  cd $CODE_ROOT/$REPO_DIR

  if [[ $2 == 'maven' ]]; then
    printf "Compiling and packaging $1 using maven... "
    mvn compile &>> $logfile
  else
    printf "Compiling and packaging $1 using sbt... "
    sbt package &>> $logfile
  fi

  if [[ $? == 0 ]]; then
    echo "$OK"
  else
    echo "$FAILED"
    STATUS=`expr $STATUS + 1`
  fi

  cd $working_dir
  unset working_dir
}

# Clone the specified project from gerrit.
_clone() {
  working_dir=`pwd`
  _hack_repo_name $1

  logfile="$LOG_DIR/$1-clone-`date '+%Y-%m-%d_%H:%M:%S'`.log"

  if [ ! -d $LOG_DIR ]; then
    mkdir $LOG_DIR
  fi

  if [[ ! -d $CODE_ROOT ]]; then
    mkdir $CODE_ROOT
  fi

  if [ "$1" = "" ]; then
    echo "You didn't specify a project name. What is the project's name on gerrit?"
    echo 'You can use the `gerrit-projects` alias to check.'
    return
  fi

  cd $CODE_ROOT

  printf "Cloning $1... "

  if [[ -d $REPO_DIR ]]; then
    echo "already cloned $SKIPPED"
    cd $working_dir
    unset working_dir
    return
  fi
  git clone ssh://$GERRIT_USERNAME@stash:29418/$1.git $REPO_DIR &>> $logfile

  if [[ $? != 0 ]]; then
    if [[ `gerrit-projects | grep $1` == "$1" ]]; then
      printf 'Something went wrong! Check the log. '
      echo $FAILED
      STATUS=`expr $STATUS + 1`
    else
      printf "That project doesn't exist on stash! "
      echo $SKIPPED
    fi

    cd $working_dir
    unset working_dir
    return
  fi

  cd $REPO_DIR
  cp -f $CHANGE_ID_HOOK .git/hooks/commit-msg

  if [[ $PYTHON_PROJECTS =~ $1 ]]; then
    cp -f $FLAKE8_HOOK .git/hooks/pre-commit
  fi

  git remote set-url origin ssh://$GERRIT_USERNAME@stash:29418/$1.git &> /dev/null
  git remote add upstream ssh://$GERRIT_USERNAME@stash:29418/$1.git &> /dev/null
  echo "Successfully cloned $1 from stash! $OK"

  cd $working_dir
  unset working_dir
}

rebaseall() {
  for project in $ALL_PROJECTS; do
    if [[ $project = 'shop' ]]; then
      _rebase $project staging
    else
      _rebase $project master
    fi
  done
}
compileall() {
  for project in $SBT_PROJECTS; do
    _compile $project
  done

  for project in $MAVEN_PROJECTS; do
    _compile $project maven
  done
}
cloneall() {
  for project in $ALL_PROJECTS; do
    _clone $project
  done
}
