# TODO: This stuff should be sourced in a work script, I'll hack it in the mean time...
# Source boxen stuff here so it's available in other places (e.g. vim)
. /opt/boxen/env.sh
# Golang
export PATH=$PATH:/opt/boxen/homebrew/opt/go/libexec/bin
# Python
export PYTHONPATH=`brew --prefix`/Cellar/python/2.7.3-boxen2
# Java
export JAVA_HOME="/Library/Internet Plug-Ins/JavaAppletPlugin.plugin/Contents/Home"
# Stops annoying dock icons popping up when running mvn stuff
export MAVEN_OPTS='-Djava.awt.headless=true'

export DOCKER_VOLUMES='/Users/laithal/docker-share'

# For the oh-my-zsh jira plugin
export JIRA_URL='https://greenmangaming.atlassian.net'

# Override the boxen config in favour of docker
export PGPORT=5432

# A $JOB_NAMESPACE env var is used to find the directory
# containing files which need to be sourced for work
# TODO: Remove this and put it in ~/.env_namespace on work machine
export WORK_NAMESPACE='gmg'

# Now source the work script to load in work specific scripts
. "$DOTFILES/.work"

# AWS keys for scaldoge
export_aws

# Dockerify the session
eval "$(docker-machine env default)"
# `fuck` will attempt to correct the last command
eval $(thefuck --alias)
