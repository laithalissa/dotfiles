#!/bin/bash
#
# Use the `JOB_NAMESPACE` env var to find the directory where
# `current work` related source files live, within the
#   $DOT_FILES/lib
# directory.
#
# For example, setting
#
# JOB_NAMESPACE=`cowfarm`
#
# will source each file in
# the $DOTFILES/lib/cowfarm/ directory
#
# HIDDEN FILES ARE IGNORED
if [[ -z $WORK_NAMESPACE ]]; then
  return
fi

if [[ -z $DOTFILES ]]; then
  return
fi

sources_dir="$DOTFILES/lib/$WORK_NAMESPACE"
if [[ ! -d $sources_dir ]]; then
  return
fi

for file in `ls "$sources_dir"`; do
  . "$DOTFILES/lib/$WORK_NAMESPACE/$file";
done;
