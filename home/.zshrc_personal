# Source a file if it exists
include () {
  [[ -f "$1" ]] && source "$1"
}

# Load Laithisms
include "$DOTFILES/.aliases"

# Nasty fat hobitsis keeps his secret keys here
include "$DOTFILES/.secrets"

# Colorize maven
include "$SCRIPTS/colourise-mvn"

# Util function
include "$SCRIPTS/functions/source-me"

# Docker wrapped tools
include ~/Code/docker/source-me

# This should give us WORK_NAMESPACE
include ~/.env_namespace

if [ $WORK_NAMESPACE ]; then
  include "$DOTFILES/.zshrc_work"
  # See ~/.zshenv for env var definitions
  # Source the gmg_vars script to get service env vars
  include ~/Code/fabric/gmg_vars.sh
fi
